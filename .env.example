# === 全局默认 LLM 配置 ===
# 创建知识库时若不指定，则使用以下默认值。
# 每个知识库可独立配置 provider / api_key / base_url / llm_model / embedding_model。
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认模型（新建知识库时使用）
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# 文档分块
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
