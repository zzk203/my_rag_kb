# LLM 配置
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v4

# OpenAI 兼容: gpt-4o-mini / glm-4.7-flash / qwen-turbo ...
OPENAI_MODEL=gpt-4o-mini
# Embedding: text-embedding-3-small / embedding-3 / bge-m3 ...
EMBEDDING_MODEL=text-embedding-3-small

# 文档分块
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
